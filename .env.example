# Tweedle environment template.
#
# Copy to `.env` and fill in real values. `.env` is gitignored; this template
# is tracked. Never put real secrets in this file.
#
#   cp .env.example .env
#
# Generate a SECRET_KEY:
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"

# ── Django core ─────────────────────────────────────────────────
# REQUIRED in production (the app refuses to boot with DEBUG off and no key).
DJANGO_SECRET_KEY=

# Leave True for local dev; set False in every non-local environment.
DJANGO_DEBUG=True

# Comma-separated hosts/domains. REQUIRED when DJANGO_DEBUG=False.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins (scheme required). REQUIRED once served over HTTPS.
DJANGO_CSRF_TRUSTED_ORIGINS=

# ── Production security (only applied when DJANGO_DEBUG=False) ───
# Optional overrides — sensible defaults are used if unset.
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SECURE_HSTS_SECONDS=31536000

# ── Email ───────────────────────────────────────────────────────
# Leave DJANGO_EMAIL_HOST unset to print emails to the console (local dev).
# Set it to switch to real SMTP delivery.
# DJANGO_EMAIL_HOST=smtp.example.com
# DJANGO_EMAIL_PORT=587
# DJANGO_EMAIL_HOST_USER=apikey-or-username
# DJANGO_EMAIL_HOST_PASSWORD=
# DJANGO_EMAIL_USE_TLS=True
DJANGO_DEFAULT_FROM_EMAIL=Tweedle <no-reply@tweedle.local>
# Absolute base URL used for links inside emails (no trailing slash).
DJANGO_BASE_URL=http://localhost:8000

# ── Database ────────────────────────────────────────────────────
# Set DB_ENGINE=postgresql to use Postgres; any other value / unset → SQLite.
DB_ENGINE=postgresql
DB_NAME=tweedle
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
